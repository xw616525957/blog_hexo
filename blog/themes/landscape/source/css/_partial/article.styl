.article
  margin: block-margin 0

.article-inner
  @extend $block
  overflow: hidden
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  &:hover
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 212, 255, 0.1)
    border-color: rgba(0, 212, 255, 0.2)

.article-meta
  clearfix()

.article-date
  @extend $block-caption
  float: left

.article-category
  float: left
  line-height: 1em
  color: color-grey
  margin-left: 8px
  &:before
    content: "\2022"
    margin-right: 4px

.article-category-link
  @extend $block-caption
  margin: 0 12px 1em
  color: color-accent-secondary

.article-header
  padding: article-padding article-padding 0

.article-title
  text-decoration: none
  font-size: 1.75em
  font-weight: 700
  color: #e6edf3
  line-height: line-height-title
  transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  a&:hover
    color: color-accent

.article-entry
  @extend $base-style
  clearfix()
  color: color-default
  padding: 0 article-padding
  p, table
    line-height: line-height
    margin: line-height 0
  h1, h2, h3, h4, h5, h6
    font-weight: 700
    color: #e6edf3
  h1, h2, h3, h4, h5, h6
    line-height: line-height-title
    margin: 1.5em 0 0.8em
    position: relative
  h2
    padding-bottom: 0.4em
    border-bottom: 1px solid color-border
  a
    color: color-link
    text-decoration: none
    transition: color 0.2s
    &:hover
      color: color-accent
      text-decoration: underline
  ul, ol, dl
    margin-top: line-height
    margin-bottom: line-height
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: auto
    border-radius: 8px
  iframe
    border: none
  table
    width: 100%
    border-collapse: collapse
    border-spacing: 0
    border-radius: 8px
    overflow: hidden
  th
    font-weight: 600
    background: rgba(56, 68, 87, 0.3)
    border-bottom: 2px solid color-border
    padding: 10px 12px
    text-align: left
    color: #e6edf3
  td
    border-bottom: 1px solid color-border
    padding: 10px 12px
  tr:hover td
    background: rgba(56, 68, 87, 0.15)
  blockquote
    font-family: font-sans
    font-size: 1.05em
    margin: 1.5em 0
    padding: 1em 1.5em
    border-left: 3px solid color-accent
    background: rgba(0, 212, 255, 0.04)
    border-radius: 0 8px 8px 0
    color: color-grey
    text-align: left
    footer
      font-size: font-size
      margin: line-height 0
      font-family: font-sans
      cite
        &:before
          content: "—"
          padding: 0 0.5em
  .pullquote
    text-align: left
    width: 45%
    margin: 0
    &.left
      margin-left: 0.5em
      margin-right: 1em
    &.right
      margin-right: 0.5em
      margin-left: 1em
  .caption
    color: color-grey
    display: block
    font-size: 0.9em
    margin-top: 0.5em
    position: relative
    text-align: center
  .video-container
    position: relative
    padding-top: (9 / 16 * 100)%
    height: 0
    overflow: hidden
    border-radius: 8px
    iframe, object, embed
      position: absolute
      top: 0
      left: 0
      width: 100%
      height: 100%
      margin-top: 0

.article-more-link a
  display: inline-block
  line-height: 1em
  padding: 8px 20px
  border-radius: 20px
  background: transparent
  color: color-accent
  border: 1px solid color-accent
  text-decoration: none
  font-size: 0.9em
  font-weight: 500
  letter-spacing: 0.5px
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  &:hover
    background: color-accent
    color: #0d1117
    text-decoration: none
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3)

.article-footer
  clearfix()
  font-size: 0.85em
  line-height: line-height
  border-top: 1px solid color-border
  padding-top: line-height
  margin: 0 article-padding article-padding
  a
    color: color-grey
    text-decoration: none
    transition: color 0.2s
    &:hover
      color: color-accent

.article-tag-list-item
  float: left
  margin-right: 10px

.article-tag-list-link
  color: color-accent !important
  font-size: 0.9em
  padding: 2px 10px
  border-radius: 12px
  background: rgba(0, 212, 255, 0.08)
  border: 1px solid rgba(0, 212, 255, 0.2)
  transition: all 0.2s
  display: inline-block
  &:before
    content: "#"
  &:hover
    background: rgba(0, 212, 255, 0.15)
    text-decoration: none !important

.article-comment-link
  float: right
  &:before
    content: "\f075"
    font-family: font-icon
    padding-right: 8px

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  &:before
    content: "\f064"
    font-family: font-icon
    padding-right: 6px

#article-nav
  clearfix()
  position: relative
  @media mq-normal
    margin: block-margin 0
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: color-border

.article-nav-link-wrap
  text-decoration: none
  color: color-grey
  box-sizing: border-box
  margin-top: block-margin
  text-align: center
  display: block
  padding: 16px
  border-radius: 12px
  border: 1px solid color-border
  background: color-surface
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  &:hover
    color: color-accent
    border-color: rgba(0, 212, 255, 0.3)
    background: color-surface-elevated
  @media mq-normal
    width: 48%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 2px
  color: color-accent
  line-height: 1em
  font-weight: 600
  font-size: 0.7em
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.9em
  line-height: line-height
  margin-top: 0.5em
  color: color-default

.article-share-box
  position: absolute
  display: none
  background: color-surface
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5)
  border: 1px solid color-border
  border-radius: 12px
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: color-default
  outline: none
  border: 1px solid color-border
  border-radius: 12px 12px 0 0
  height: 36px
  line-height: 36px

.article-share-links
  clearfix()
  background: color-surface-elevated

$article-share-link
  width: 50px
  height: 36px
  display: block
  float: left
  position: relative
  color: color-grey
  transition: all 0.2s
  &:before
    font-size: 20px
    font-family: font-icon
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:before
    content: "\f099"
  &:hover
    background: color-twitter

.article-share-facebook
  @extend $article-share-link
  &:before
    content: "\f09a"
  &:hover
    background: color-facebook

.article-share-pinterest
  @extend $article-share-link
  &:before
    content: "\f0d2"
  &:hover
    background: color-pinterest

.article-share-google
  @extend $article-share-link
  &:before
    content: "\f0d5"
  &:hover
    background: color-google

.article-gallery
  background: #000
  position: relative

.article-gallery-photos
  position: relative
  overflow: hidden

.article-gallery-img
  display: none
  max-width: 100%
  &:first-child
    display: block
  &.loaded
    position: absolute
    display: block
  img
    display: block
    max-width: 100%
    margin: 0 auto
