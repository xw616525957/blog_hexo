@media mq-mobile
  #mobile-nav
    position: absolute
    top: 0
    left: 0
    width: mobile-nav-width
    height: 100%
    background: color-mobile-nav-background
    border-right: 1px solid color-border

@media mq-mobile
  .mobile-nav-link
    display: block
    color: color-grey
    text-decoration: none
    padding: 15px 20px
    font-weight: 500
    border-bottom: 1px solid rgba(56, 68, 87, 0.3)
    transition: all 0.2s
    &:hover
      color: color-accent
      background: rgba(0, 212, 255, 0.05)
