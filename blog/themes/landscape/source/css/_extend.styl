$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 2px
  color: color-accent
  margin-bottom: 1em
  margin-left: 0
  line-height: 1em
  font-weight: 600
  font-size: 0.75em

$block
  background: color-surface
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.04)
  border: 1px solid color-border
  border-radius: 12px

$base-style
  h1
    font-size: 2em
  h2
    font-size: 1.5em
  h3
    font-size: 1.3em
  h4
    font-size: 1.15em
  h5
    font-size: 1em
  h6
    font-size: 1em
    color: color-grey
  hr
    border: none
    height: 1px
    background: linear-gradient(to right, transparent, color-border, transparent)
    margin: 2em 0
  strong
    font-weight: 600
    color: #e6edf3
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted
  ul, ol, dl
    margin: 0 20px
    line-height: line-height
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: disc
  ol
    list-style: decimal
  dt
    font-weight: bold
